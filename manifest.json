{
  "manifest_version": 3,
  "name": "PiP Anywhere",
  "version": "1.0.0",
  "description": "Enable Picture-in-Picture on any site — Netflix, Prime Video, and more.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Force Picture-in-Picture",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-pip": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Force Picture-in-Picture on the current tab"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
